APP_NAME=Media Traffic AI Analyst

# Atualmente o projeto opera apenas em modo dev.
APP_ENV=dev
APP_DEBUG=true

# Opcional (quando vazio, o client tenta inferir automaticamente)
GCP_PROJECT_ID=

# Mantenha este valor e coloque o arquivo de credenciais em credentials/google.json
GOOGLE_APPLICATION_CREDENTIALS=credentials/google.json

# Provider principal do LLM
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini

# Credenciais por provider
OPENAI_API_KEY=your-openai-key
ANTHROPIC_API_KEY=

# Fallback opcional
LLM_FALLBACK_PROVIDER=
LLM_FALLBACK_MODEL=

# Ollama — provider de modelos open source (remoto/cloud)
# OLLAMA_BASE_URL e obrigatorio quando LLM_PROVIDER=ollama.
# OLLAMA_API_KEY e opcional (apenas se o endpoint exigir autenticacao Bearer).
# Exemplo: LLM_PROVIDER=ollama, LLM_MODEL=llama3.1
OLLAMA_BASE_URL=
OLLAMA_API_KEY=

# LangSmith — observabilidade opt-in (deixe em branco para desativar)
# Crie conta em smith.langchain.com, gere uma API key e defina o nome do projeto.
# Todas as tres vars sao necessarias para ativar o tracing.
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=media-traffic-ai-analyst
